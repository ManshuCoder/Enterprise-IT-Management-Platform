# ============================================================
# EIMP Frontend — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# For Vercel deployment, set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# Backend API base URL (include /api suffix)
# Local:      http://localhost:5000/api
# Production: https://<your-render-service>.onrender.com/api
NEXT_PUBLIC_API_URL=https://<your-render-service>.onrender.com/api

# Backend WebSocket URL (no /api suffix)
# Local:      http://localhost:5000
# Production: https://<your-render-service>.onrender.com
NEXT_PUBLIC_SOCKET_URL=https://<your-render-service>.onrender.com

# Clerk Authentication (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
